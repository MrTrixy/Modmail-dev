# Bot Configuration
TOKEN=your_bot_token_here

# Optional Configuration
LOG_LEVEL=info
MAIN_CATEGORY_ID=
FALLBACK_CATEGORY_ID=
PREFIX=?
MENTION=@here
MAIN_COLOR=5865f2
ERROR_COLOR=ff0000

# Thread Auto-Close
THREAD_AUTO_CLOSE=1d
THREAD_AUTO_CLOSE_SILENTLY=false

# Snooze Configuration
SNOOZE_DEFAULT_DURATION=604800
SNOOZE_BEHAVIOR=delete
SNOOZED_CATEGORY_ID=
SNOOZE_STORE_ATTACHMENTS=false